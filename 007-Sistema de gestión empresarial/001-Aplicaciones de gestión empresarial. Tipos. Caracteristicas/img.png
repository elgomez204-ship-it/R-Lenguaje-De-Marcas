@charset "utf-8";

.richImage { display: inline-block; }

.richImage ul { list-style-type: none; padding: 0px; margin: 0px; }

.richImage .imgContainer { display: inline-block; position: relative; }

.richImage .hoverContainer { display: block; position: absolute; bottom: 0p=
x; width: 100%; box-sizing: border-box; }

.richImage .hoverContainer { display: none; }

.richImage:hover .hoverContainer, .richImage.focus .hoverContainer { displa=
y: block; }

.richImage img { vertical-align: top; }

.richImage img.ext { object-fit: contain; }

.oneCol #actionbar li:nth-child(1) .noti_container.nt.vs, .oneCol #actionba=
r li:nth-child(1) .noti_container.nt.hs { left: -30px; }

.oneCol #actionbar li:nth-child(2) .noti_container.nt.vs, .oneCol #actionba=
r li:nth-child(2) .noti_container.nt.hs { left: 65px; }

.oneCol #actionbar li:nth-child(3) .noti_container.nt.vs, .oneCol #actionba=
r li:nth-child(3) .noti_container.nt.hs { left: 100px; }

.twoCol #actionbar li:nth-child(1) .noti_container.nt { left: -110px; }

