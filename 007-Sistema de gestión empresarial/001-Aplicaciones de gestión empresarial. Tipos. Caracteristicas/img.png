@charset "utf-8";

span.finft { animation: 0.5s cubic-bezier(0.52, 0, 0.18, 0.9) 0s 1 normal f=
orwards running finft; }

span.finfb { animation: 0.5s cubic-bezier(0.52, 0, 0.18, 0.9) 0s 1 normal f=
orwards running finfb; }

span.fouttt { animation: 0.5s cubic-bezier(0.52, 0, 0.18, 0.9) 0s 1 normal =
forwards running fouttt; }

span.fouttb { animation: 0.5s cubic-bezier(0.52, 0, 0.18, 0.9) 0s 1 normal =
forwards running fouttb; }

@keyframes finft {=20
  0% { transform: translateY(-50px); opacity: 0; }
  100% { transform: translateY(0px); opacity: 1; }
}

@keyframes finfb {=20
  0% { transform: translateY(50px); opacity: 0; }
  100% { transform: translateY(0px); opacity: 1; }
}

@keyframes fouttt {=20
  0% { transform: translateY(0px); opacity: 1; }
  100% { transform: translateY(-50px); opacity: 0; }
}

@keyframes fouttb {=20
  0% { transform: translateY(0px); opacity: 1; }
  100% { transform: translateY(50px); opacity: 0; }
}
