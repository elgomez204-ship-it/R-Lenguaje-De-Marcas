.obj_det_container [data-tooltip].left-tooltip:not(.disableTooltip):hover::=
after { transform: translateX(-10%); }

.obj_det_container [data-tooltip].right-tooltip:not(.disableTooltip):hover:=
:after { transform: translateX(-90%); }

.obj_det_container [data-tooltip]:not(.disableTooltip):hover::before { bott=
om: 18px; }

