cus ~ .cb_t { border: 1px dashed rgb(136, 136, 136); }

.cb_c .cb_w::after { position: absolute; content: ""; }

.cb_c input:checked ~ .cb_w::after { transform: rotate(45deg) scale(1); opa=
city: 1; left: 4px; width: 6px; height: 12px; border-style: solid; border-c=
olor: rgb(255, 255, 255); border-image: initial; border-width: 0px 2px 2px =
0px; background-color: transparent; border-radius: 0px; }

#checkbox_region > div { text-align: left; }

